---
import { Card, CardContent } from "../ui/components/card.tsx"
import { formatDate } from "../lib/utils.ts"

interface Props {
  author?: string
  publishDate: Date
}

const { author, publishDate } = Astro.props
---

<Card className="mt-8">
  <CardContent className="flex flex-col gap-1 py-4 text-sm text-muted-foreground">
    <p>
      <span aria-hidden="true">©</span>
      {author ? `This work by ${author} is` : "This work is"}
      licensed under
      <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer" class="font-medium" style="color: var(--link, var(--primary))">
        CC BY 4.0
      </a>.
    </p>
    <p class="text-xs">Published {formatDate(publishDate)}.</p>
  </CardContent>
</Card>
