---
import Layout from "@/layouts/Layout.astro"
import MDXContent from "@/components/MDXContent.astro"
import { User } from "lucide-react"
import { Badge } from "@workspace/ui/components/badge"
import { Button } from "@workspace/ui/components/button"
import { Separator } from "@workspace/ui/components/separator"
import { getCollection, render } from "astro:content"
import svgPaths from "@/generated/svg-paths.json"

const profilePaths = svgPaths.find((h) => h.key === "profile")!

const profiles = await getCollection("profile")
const profile = profiles[0]

if (!profile) {
  throw new Error("No profile content found")
}

const { Content } = await render(profile)
const { name, role, bio, avatar, social, skills, resumeLink } = profile.data
---

<Layout title="Profile" description={bio}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <div data-animate="profile-block" class="mb-8 flex flex-col items-center gap-4 text-center md:flex-row md:text-left">
      <div class="relative flex size-24 shrink-0 overflow-hidden rounded-full bg-muted ring-2 ring-border">
        {
          avatar ? (
            <img src={avatar} alt={name} class="size-full object-cover" />
          ) : (
            <span class="flex size-full items-center justify-center text-muted-foreground">
              <User className="size-10" />
            </span>
          )
        }
      </div>
      <div>
        <div data-animate="page-heading" role="heading" aria-level="1">
          <svg
            viewBox={`0 0 ${Math.ceil(profilePaths.totalWidth + 6)} ${profilePaths.height + 6}`}
            width="100%"
            height="auto"
            style={`max-width: ${Math.ceil(profilePaths.totalWidth + 6)}px; display: block; overflow: visible;`}
            xmlns="http://www.w3.org/2000/svg"
            aria-label={name}
            role="img"
          >
            <g transform="translate(3, 3)" opacity="0.45" fill="none" stroke="var(--highlight)" stroke-width="1" stroke-linejoin="round">
              {profilePaths.glyphs.map((g) => <path d={g.d} />)}
            </g>
            <g transform="translate(3, 3)" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linejoin="round" class="draw-paths">
              {profilePaths.glyphs.map((g) => <path d={g.d} class="draw-path" />)}
            </g>
          </svg>
        </div>
        <p class="text-lg text-muted-foreground">{role}</p>
        <div class="mt-3 flex flex-wrap justify-center gap-2 md:justify-start">
          {skills.map((skill: string) => <span data-animate="badge"><Badge variant="secondary">{skill}</Badge></span>)}
        </div>
      </div>
    </div>

    <div class="mb-8 flex flex-wrap justify-center gap-3 md:justify-start">
      {
        social.map((item: { name: string; url: string }) => (
          <span data-animate="social-btn">
            <Button variant="outline" size="sm" asChild>
              <a href={item.url} target="_blank" rel="noopener noreferrer">
                {item.name}
              </a>
            </Button>
          </span>
        ))
      }
      {
        resumeLink && (
          <span data-animate="social-btn">
            <Button size="sm" asChild>
              <a href={resumeLink} target="_blank" rel="noopener noreferrer">
                Resume
              </a>
            </Button>
          </span>
        )
      }
    </div>

    <Separator className="mb-8" />

    <MDXContent>
      <Content />
    </MDXContent>
  </section>
</Layout>
