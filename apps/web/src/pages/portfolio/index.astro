---
import Layout from "@/layouts/Layout.astro"
import ProjectCard from "@/components/ProjectCard.astro"
import MDXContent from "@/components/MDXContent.astro"
import { Badge } from "@workspace/ui/components/badge"
import { siteConfig } from "@/site.config"
import { getCollection, render } from "astro:content"
import type { CollectionEntry } from "astro:content"
import svgPaths from "@/generated/svg-paths.json"

const portfolioPaths = svgPaths.find((h) => h.key === "portfolio")!

const projects: CollectionEntry<"projects">[] = (await getCollection("projects")).sort(
  (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
    (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
)

const projectRenders = await Promise.all(
  projects.map(async (project: CollectionEntry<"projects">) => {
    const { Content } = await render(project)
    return { project, Content }
  })
)
---

<Layout title="Portfolio" description="Selected projects and case studies.">
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div data-animate="page-heading" class="mb-4" role="heading" aria-level="1">
      <svg
        viewBox={`0 0 ${Math.ceil(portfolioPaths.totalWidth + 6)} ${portfolioPaths.height + 6}`}
        width="100%"
        height="auto"
        style={`max-width: ${Math.ceil(portfolioPaths.totalWidth + 6)}px; display: block; overflow: visible;`}
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Portfolio"
        role="img"
      >
        <g transform="translate(3, 3)" opacity="0.45" fill="none" stroke="var(--highlight)" stroke-width="1" stroke-linejoin="round">
          {portfolioPaths.glyphs.map((g) => <path d={g.d} />)}
        </g>
        <g transform="translate(3, 3)" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linejoin="round" class="draw-paths">
          {portfolioPaths.glyphs.map((g) => <path d={g.d} class="draw-path" />)}
        </g>
      </svg>
    </div>
    <p data-animate="section-heading" class="mb-4 text-muted-foreground">Selected projects and case studies.</p>

    {
      siteConfig.portfolio.enabled && siteConfig.portfolio.mode !== "single-page" && (
        <a href="/portfolio/tags" class="mb-8 inline-block text-sm font-medium text-highlight">Browse tags</a>
      )
    }

    {
      !siteConfig.portfolio.enabled ? (
        <div class="rounded-lg border border-border p-8 text-center">
          <p class="text-muted-foreground">Portfolio is currently disabled.</p>
        </div>
      ) : siteConfig.portfolio.mode === "single-page" ? (
        <div class="flex flex-col gap-12">
          {projectRenders.map(({ project, Content }) => (
            <article class="markdown">
              <h2>{project.data.title}</h2>
              <p class="text-muted-foreground">{project.data.description}</p>
              <div class="mb-4 flex flex-wrap gap-2">
                {project.data.tags.map((t: string) => (
                  <Badge variant="secondary">{t}</Badge>
                ))}
              </div>
              <MDXContent>
                <Content />
              </MDXContent>
            </article>
          ))}
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {projects.map((project: CollectionEntry<"projects">) => (
            <div data-animate="card"><ProjectCard project={project} /></div>
          ))}
        </div>
      )
    }
  </section>
</Layout>
