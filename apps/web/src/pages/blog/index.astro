---
import Layout from "@/layouts/Layout.astro"
import ArticleCard from "@/components/ArticleCard.astro"
import { getCollection } from "astro:content"
import type { CollectionEntry } from "astro:content"
import svgPaths from "@/generated/svg-paths.json"

const blogPaths = svgPaths.find((h) => h.key === "blog")!

const articles: CollectionEntry<"articles">[] = (await getCollection("articles"))
  .filter((a: CollectionEntry<"articles">) => !a.data.draft)
  .sort((a: CollectionEntry<"articles">, b: CollectionEntry<"articles">) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
---

<Layout title="Blog" description="Articles on frontend engineering, design systems, and static-site generators.">
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="mb-8">
      <div data-animate="page-heading" class="mb-3" role="heading" aria-level="1">
        <svg
          viewBox={`0 0 ${Math.ceil(blogPaths.totalWidth + 6)} ${blogPaths.height + 6}`}
          width="100%"
          height="auto"
          style={`max-width: ${Math.ceil(blogPaths.totalWidth + 6)}px; display: block; overflow: visible;`}
          xmlns="http://www.w3.org/2000/svg"
          aria-label="Blog"
          role="img"
        >
          <g transform="translate(3, 3)" opacity="0.45" fill="none" stroke="var(--highlight)" stroke-width="1" stroke-linejoin="round">
            {blogPaths.glyphs.map((g) => <path d={g.d} />)}
          </g>
          <g transform="translate(3, 3)" fill="none" stroke="var(--primary)" stroke-width="1.5" stroke-linejoin="round" class="draw-paths">
            {blogPaths.glyphs.map((g) => <path d={g.d} class="draw-path" />)}
          </g>
        </svg>
      </div>
      <p data-animate="section-heading" class="mt-2 text-muted-foreground">Articles on frontend engineering, design systems, and static-site generators.</p>
      <a href="/tags" class="mt-2 inline-block text-sm font-medium text-highlight">Browse tags</a>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((article: CollectionEntry<"articles">) => (
        <div data-animate="card"><ArticleCard article={article} /></div>
      ))}
    </div>
  </section>
</Layout>
