---
import { siteConfig } from "@/site.config"
import { ThemePicker } from "@/components/ThemePicker"
import { GlobalSearch } from "@/components/GlobalSearch"
import { MobileNav } from "@/components/MobileNav"
import { getCollection } from "astro:content"
import type { SearchItem } from "@/components/GlobalSearch"

const navLinks = [...siteConfig.nav]
if (siteConfig.portfolio.enabled) {
  navLinks.push({ label: "Portfolio", href: "/portfolio" })
}
navLinks.push({ label: "Profile", href: "/profile" })

const articles = (await getCollection("articles")).filter((a) => !a.data.draft)
const projects = siteConfig.portfolio.enabled ? await getCollection("projects") : []

const searchItems: SearchItem[] = [
  ...articles.map((a) => ({
    title: a.data.title,
    description: a.data.description,
    href: `/blog/${a.id}`,
    type: "article" as const,
  })),
  ...projects.map((p) => ({
    title: p.data.title,
    description: p.data.description,
    href: `/portfolio/${p.id}`,
    type: "project" as const,
  })),
]
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4">
    <a href="/" class="text-lg font-semibold tracking-tight">
      {siteConfig.title}
    </a>
    <nav class="hidden items-center gap-1 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            class="nav-link rounded-md px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          >
            {link.label}
          </a>
        ))
      }
      <GlobalSearch client:load items={searchItems} />
      <ThemePicker client:load />
    </nav>
    <MobileNav client:load navLinks={navLinks} searchItems={searchItems} />
  </div>
</header>

<style>
  .nav-link:hover {
    color: var(--foreground) !important;
  }
  .nav-link[aria-current="page"] {
    color: var(--primary);
    background-color: color-mix(in srgb, var(--primary) 10%, transparent);
  }
  .nav-link[aria-current="page"]:hover {
    color: var(--primary) !important;
  }
</style>

<script>
  function markActiveLink() {
    const links = document.querySelectorAll<HTMLAnchorElement>("a[data-nav-link]")
    const current = window.location.pathname
    for (const link of links) {
      const href = new URL(link.href).pathname
      const isActive = href === "/" ? current === "/" : current.startsWith(href)
      link.setAttribute("aria-current", isActive ? "page" : "false")
    }
  }
  markActiveLink()
  document.addEventListener("astro:page-load", markActiveLink)
</script>
